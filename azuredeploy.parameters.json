    "defaultBudgetAmount": {
      "type": "int",
      "defaultValue": 100
    },
    "enableAmortizedPipeline": {
      "type": "bool",
      "defaultValue": false
    },
    "enableAutoBudget": {
      "type": "bool",
      "defaultValue": true
    },
    "enableSelfServiceChange": {
      "type": "bool",
      "defaultValue": true
    },
    "enablePolicy": {
      "type": "bool",
      "defaultValue": true
    },
    "enableRbacAssignment": {
      "type": "bool",
      "defaultValue": true
    }
  }
}
